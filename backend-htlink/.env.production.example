# Domain
DOMAIN=your-domain.example.com

# Used by the backend to generate links in emails to the frontend
FRONTEND_HOST=https://your-domain.example.com
VITE_API_URL=https://api.your-domain.example.com

# Environment: local, staging, production
ENVIRONMENT=production

PROJECT_NAME="VR Restaurant"
STACK_NAME=hotellink

# Backend
BACKEND_CORS_ORIGINS=["https://your-domain.example.com","https://api.your-domain.example.com"]
ALLOW_LOCALHOST_CORS=false

SECRET_KEY=replace-with-a-long-random-secret
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=change-me

# Emails
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

DEEPL_API_KEY=your-deepl-api-key
#GOOGLE_CLOUD_API_KEY=your-google-cloud-api-key-here

MYSQL_SERVER=your-db-host.example.com
MYSQL_PORT=3306
MYSQL_DATABASE=vr_restaurant_db
MYSQL_USER=vr_restaurant_user
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me

SENTRY_DSN=

# Configure these with your own Docker registry images
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend
