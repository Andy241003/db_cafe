# PRODUCTION ENVIRONMENT VARIABLES FOR HOTELLINK 360 SAAS
# Copy this file to your production server as .env.production

# Domain Configuration
DOMAIN=travel.link360.vn
FRONTEND_HOST=https://travel.link360.vn
ENVIRONMENT=production

# Project Settings
PROJECT_NAME="Hotel Link 360 SaaS"
STACK_NAME=hotellink360

# Backend Configuration  
BACKEND_CORS_ORIGINS="https://travel.link360.vn,https://www.travel.link360.vn"
SECRET_KEY=8f9e6d7c2b4a5e8f1a9b3c7e4d6f9a2e5b8c1f4a7d9e6c3f8b1a4e7d2c5f9a8b
FIRST_SUPERUSER=admin@travel.link360.vn
FIRST_SUPERUSER_PASSWORD=SuperSecretPass123

# Email Configuration (Update with your SMTP settings)
SMTP_HOST=smtp.gmail.com
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM_EMAIL=noreply@travel.link360.vn
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# MySQL Database Configuration
MYSQL_SERVER=db
MYSQL_PORT=3306
MYSQL_DATABASE=hotellink360_db
MYSQL_USER=hotellink360_user
MYSQL_PASSWORD=StrongDBPassword2024!
MYSQL_ROOT_PASSWORD=VeryStrongRootPass2024!

# Monitoring (Optional)
SENTRY_DSN=

# Docker Images (Update if using custom registry)
DOCKER_IMAGE_BACKEND=backend-htlink-backend:latest
DOCKER_IMAGE_FRONTEND=backend-htlink-frontend:latest

# Multi-Tenant Settings
DEFAULT_TENANT_CODE=demo
ENABLE_MULTI_TENANT=true

# API Settings
API_V1_STR=/api/v1
ACCESS_TOKEN_EXPIRE_MINUTES=60